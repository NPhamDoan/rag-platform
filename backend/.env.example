# Cau hinh moi truong cho backend Multi-User RAG Platform.
# Sao chep file nay thanh `.env` va dien gia tri thuc. KHONG commit `.env`.

# Moi truong: development | production (anh huong log level)
ENVIRONMENT=development

# CORS (danh sach origin, vd: ["http://localhost:5173"])
# CORS_ORIGINS=["*"]

# --- Xac thuc ---
# Khoa HMAC ky token phien (BAT BUOC doi o production)
SECRET_KEY=dev-secret-change-me
SESSION_TTL_MINUTES=60
LOGIN_MAX_FAILS=5
LOGIN_LOCK_MINUTES=15

# --- Ma hoa khoa API nguoi dung (Fernet, R22) ---
# Sinh bang: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY_ENCRYPT=

# --- LLM / Embedding provider (R13, R21) ---
LLM_TIMEOUT_SECONDS=30
LLM_PRIMARY_PROVIDER=groq
LLM_VERIFY_PROVIDER=gemini
# Trong = dung chung provider xac minh (R13.4)
LLM_NORMALIZE_PROVIDER=
EMBEDDING_PROVIDER=huggingface

# --- Tai lieu ---
MAX_FILE_SIZE_MB=50

# --- Cau hinh truy xuat mac dinh ---
NGUONG_KHONG_TIM_THAY=0.3
NGUONG_DU_LIEN_QUAN=0.5
RETRIEVAL_K=8
TRONG_SO_VECTOR=0.5
TRONG_SO_BM25=0.5

# --- Han muc mac dinh ---
QUOTA_SO_KHONG_GIAN=50
# 5GB tinh theo byte
QUOTA_DUNG_LUONG=5368709120
QUOTA_SO_TAI_LIEU=1000
QUOTA_TAN_SUAT_TRUY_VAN=60

# --- Co so du lieu (de trong = SQLite mac dinh tai backend/data/app.db) ---
# DATABASE_URL=sqlite:///./data/app.db
